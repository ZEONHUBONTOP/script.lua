-- ABA: AUTO STAR
----------------------------------------------------------------
-- Seção de Ovos (Eggs)
Tabs.Stars:AddSection("Auto Open Eggs")

Tabs.Stars:AddDropdown("StarDropdown", { Title = "Selecionar Mundo", Values = {"World1", "World2"}, Multi = false, Default = "World1" })

Tabs.Stars:AddToggle("EggToggle", {Title = "Ativar Auto Open (0.01s)", Default = false }):OnChanged(function()
    task.spawn(function()
        while Options.EggToggle.Value do
            local event = game:GetService("ReplicatedStorage"):WaitForChild("simpledeev_Framework"):WaitForChild("Library"):WaitForChild("Network"):WaitForChild("Events"):FindFirstChild("OpenEgg")
            if event then event:FireServer(Options.StarDropdown.Value) end
            task.wait(0.01)
        end
    end)
end)

-- Seção de Gacha (0.01s)
Tabs.Stars:AddSection("Auto Gacha")

local GachaList = {
    ["BijusPower W1"] = "World1_Bijuus",
    ["EyesPower W1"] = "World1_Eyes",
    ["SaiyanPower W2"] = "World2_Saiya"
}

Tabs.Stars:AddDropdown("GachaDropdown", {
    Title = "Selecionar Gachas",
    Values = {"BijusPower W1", "EyesPower W1", "SaiyanPower W2"},
    Multi = true,
    Default = {},
})

Tabs.Stars:AddToggle("GachaToggle", {Title = "Ativar Auto Gacha (0.01s)", Default = false }):OnChanged(function()
    task.spawn(function()
        local remote = game:GetService("ReplicatedStorage"):WaitForChild("simpledeev_Framework"):WaitForChild("Library"):WaitForChild("Network"):WaitForChild("Functions"):WaitForChild("RollGacha")
        
        while Options.GachaToggle.Value do
            for name, isSelected in pairs(Options.GachaDropdown.Value) do
                if isSelected and Options.GachaToggle.Value then
                    remote:InvokeServer(GachaList[name])
                end
            end
            task.wait(0.01) -- Velocidade turbo solicitada
        end
    end)
end)

Window:SelectTab(1)
